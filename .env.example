# --- Supabase (Dashboard → Project Settings → API) ---
# URL da API REST (https://xxx.supabase.co) — NÃO use postgresql:// aqui
SUPABASE_URL=https://SEU_REF.supabase.co
# Chave do backend: use a "service_role" (Settings → API → service_role secret).
# Nunca commite a chave real. Não exponha service_role no frontend.
SUPABASE_KEY=

# Opcional: ref do projeto (aparece na URL do dashboard) — útil para MCP no Cursor
# SUPABASE_PROJECT_REF=

# --- App ---
# Obrigatória se FLASK_ENV=production ou ENV=production
SECRET_KEY=gere-uma-string-longa-aleatoria
# HTTPS atrás de proxy: defina 1 para cookie Secure
# SESSION_COOKIE_SECURE=1
TELEGRAM_BOT_TOKEN=

# --- IA (parser de mensagens) ---
# Provedor: gemini (padrão, com visão em imagens) | openai_compatible (ex.: Groq gratuito, só texto)
# LLM_PROVIDER=gemini

# Google AI Studio / Gemini (tier gratuito): https://ai.google.dev
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# API estilo OpenAI — ex.: Groq (https://console.groq.com) ou OpenRouter
# LLM_PROVIDER=openai_compatible
# OPENAI_COMPATIBLE_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_COMPATIBLE_API_KEY=
# OPENAI_COMPATIBLE_MODEL=llama-3.1-8b-instant
